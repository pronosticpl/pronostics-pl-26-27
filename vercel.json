{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/premier-league", "dest": "/api/premier-league.js" },
    { "src": "/api/state", "dest": "/api/state.js" },
    { "src": "/api/key", "dest": "/api/key.js" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/client.js", "dest": "/public/client.js" },
    { "src": "/styles.css", "dest": "/public/styles.css" },
    { "src": "/favicon.ico", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
